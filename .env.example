# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# LLM — оставь пустым если используешь OpenClaw (рекомендуется)
# Заполни только если хочешь прямой вызов API без OpenClaw
LLM_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5

# Путь к openclaw CLI (обычно просто "openclaw" если в PATH)
OPENCLAW_BIN=openclaw

# Расписание дайджеста
DIGEST_TIME=09:00
DIGEST_DAY=monday

# GitHub token для git pull в update.sh
# GITHUB_TOKEN=ghp_...
